<?xml version="1.0"?>
<!--
  D435 + RTAB-Map RGB-D SLAM
  ===========================
  Starts the RealSense D435 camera driver, RTAB-Map SLAM node,
  and the RTAB-Map visualizer (rtabmapviz) for real-time 3D mapping.

  Usage:
    roslaunch d435_rtabmap.launch                    # fresh map each time
    roslaunch d435_rtabmap.launch rtabmap_args:=""   # keep map across restarts
    roslaunch d435_rtabmap.launch rviz:=true         # also open RViz

  Key topics published:
    /rtabmap/mapData      — 3D point cloud + occupancy grid
    /rtabmap/graphData    — pose graph (nodes + loop closures)
    /rtabmap/info         — status info (odometry, inliers, loop closures)
    /rtabmap/odom         — visual odometry
    /rtabmap/grid_map     — 2D occupancy grid (rostopic echo to see)
    /rtabmap/camera_pose  — current camera pose estimate
-->
<launch>

  <!-- ===== Arguments ===== -->
  <arg name="camera"        default="camera"                  doc="Camera namespace"/>
  <arg name="rviz"          default="false"                   doc="Also launch RViz"/>
  <arg name="rtabmap_args"  default="--delete_db_on_start"    doc="Extra args for rtabmap node. Set to empty to keep map across restarts."/>
  <arg name="rtabmapviz_args" default=""                      doc="Extra args for rtabmapviz"/>

  <!-- ================================================================= -->
  <!-- 1. Intel RealSense D435 Camera Driver                             -->
  <!-- ================================================================= -->
  <include file="$(find realsense2_camera)/launch/rs_camera.launch">
    <!-- Name the camera namespace -->
    <arg name="camera"              value="$(arg camera)"/>

    <!-- Enable depth-color alignment (required for RGB-D SLAM) -->
    <arg name="align_depth"         value="true"/>

    <!-- Synchronize streams so color+depth frames have matching timestamps -->
    <arg name="enable_sync"         value="true"/>

    <!-- Stream config: 640x480 @ 30 Hz depth, 15 Hz color (conserves USB bandwidth) -->
    <arg name="depth_width"         value="640"/>
    <arg name="depth_height"        value="480"/>
    <arg name="depth_fps"           value="15"/>
    <arg name="color_width"         value="640"/>
    <arg name="color_height"        value="480"/>
    <arg name="color_fps"           value="15"/>

    <!-- Disable infrared streams (not needed for RGB-D SLAM) -->
    <arg name="enable_infra1"       value="false"/>
    <arg name="enable_infra2"       value="false"/>

    <!-- Disable IMU (not needed for RGB-D SLAM, frees USB bandwidth) -->
    <arg name="enable_gyro"         value="false"/>
    <arg name="enable_accel"        value="false"/>

    <!-- Publish TF frames (camera_link -> camera_*_frame) -->
    <arg name="publish_tf"          value="true"/>

    <arg name="json_file_path"       value="/home/fu/yolo/slam/d435_low_speed.json"/>
  </include>

  <!-- ================================================================= -->
  <!-- 2. RTAB-Map RGB-D SLAM Node                                       -->
  <!-- ================================================================= -->
  <node name="rtabmap" pkg="rtabmap_slam" type="rtabmap" output="screen"
        args="$(arg rtabmap_args)">

    <!-- === Topic remapping === -->
    <!-- Color image (from aligned D435) -->
    <remap from="rgb/image"         to="/$(arg camera)/color/image_raw"/>
    <!-- Depth image (aligned to color frame by realsense2_camera) -->
    <remap from="depth/image"       to="/$(arg camera)/aligned_depth_to_color/image_raw"/>
    <!-- Camera intrinsics (color intrinsics, since depth is aligned to color) -->
    <remap from="rgb/camera_info"   to="/$(arg camera)/color/camera_info"/>

    <!-- === Core parameters === -->
    <param name="subscribe_depth"   value="true"/>    <!-- Enable RGB-D mode -->
    <param name="rgbd_sync"         value="true"/>    <!-- Exact timestamp sync -->
    <param name="approx_sync"       value="false"/>   <!-- Strict matching -->
    <param name="queue_size"        value="10"/>       <!-- Input queue size -->

    <!-- === TF frames === -->
    <param name="frame_id"          value="camera_link"/>   <!-- Camera base frame -->
    <param name="odom_frame_id"     value="odom"/>          <!-- Odometry frame -->
    <param name="map_frame_id"      value="map"/>           <!-- Map frame -->
    <param name="ground_truth_frame_id" value=""/>           <!-- No external ground truth -->
    <param name="publish_tf"        value="true"/>          <!-- Broadcast map->odom -->

    <!-- === Database === -->
    <param name="database_path"     value="$(env HOME)/.ros/rtabmap.db"/>

    <!-- === Visual Odometry: 3D→3D ICP on RGB-D point clouds === -->
    <param name="Vis/EstimationType"    value="1"/>     <!-- 1 = 3D→3D (PnP not possible without feature extraction config, use ICP) -->
    <param name="Vis/MinInliers"        value="10"/>    <!-- Min feature inliers for valid odometry -->
    <param name="Odom/Strategy"         value="0"/>     <!-- 0 = Frame-to-Map (most accurate) -->
    <param name="OdomF2M/MaxSize"       value="1000"/>   <!-- Max points in local map -->

    <!-- === Memory / map update === -->
    <param name="Mem/UseOdomFeatures"       value="true"/>
    <param name="RGBD/LinearUpdate"         value="0.01"/>   <!-- Min 1cm translation to create new node -->
    <param name="RGBD/AngularUpdate"        value="0.01"/>   <!-- Min ~0.5deg rotation to create new node -->
    <param name="RGBD/OptimizeFromGraphEnd" value="true"/>   <!-- Optimize from latest node -->

    <!-- === Loop Closure === -->
    <param name="Kp/MaxFeatures"            value="400"/>    <!-- Visual words for loop detection -->
    <param name="Vis/MaxFeatures"           value="1000"/>   <!-- Features for visual odometry -->

    <!-- === Output === -->
    <param name="RGBD/ProximityBySpace"     value="true"/>   <!-- Filter loop closures by spatial proximity -->
    <param name="RGBD/LocalRadius"          value="5.0"/>    <!-- Radius for local loop closure search (meters) -->
  </node>

  <!-- ================================================================= -->
  <!-- 3. RTAB-Map Visualizer (standalone 3D map viewer)                  -->
  <!-- ================================================================= -->
  <node name="rtabmapviz" pkg="rtabmap_viz" type="rtabmap_viz" output="screen"
        args="$(arg rtabmapviz_args)">
    <!-- Image topics for current frame display -->
    <remap from="rgb/image"         to="/$(arg camera)/color/image_raw"/>
    <remap from="depth/image"       to="/$(arg camera)/aligned_depth_to_color/image_raw"/>
    <remap from="rgb/camera_info"   to="/$(arg camera)/color/camera_info"/>

    <param name="subscribe_depth"   value="true"/>
    <param name="frame_id"          value="camera_link"/>
    <param name="odom_frame_id"     value="odom"/>
  </node>

  <!-- ================================================================= -->
  <!-- 4. RViz (optional, launch with rviz:=true)                         -->
  <!-- ================================================================= -->
  <node if="$(arg rviz)" name="rviz" pkg="rviz" type="rviz"
        args="-d $(find rtabmap_launch)/launch/config/rgbd.rviz"/>

</launch>
