<?xml version="1.0"?>
<sdf version="1.6">
  <model name="pan_tilt_camera">

    <!-- ============================================ -->
    <!-- Base — fixed to world                        -->
    <!-- ============================================ -->
    <link name="base_link">
      <pose>0 0 0.5 0 0 0</pose>
      <inertial>
        <mass>0.1</mass>
        <inertia>
          <ixx>0.001</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.001</iyy><iyz>0</iyz>
          <izz>0.001</izz>
        </inertia>
      </inertial>
      <visual name="base_visual">
        <geometry><cylinder><radius>0.05</radius><length>0.4</length></cylinder></geometry>
        <material><ambient>0.3 0.3 0.3 1</ambient></material>
      </visual>
      <collision name="base_collision">
        <geometry><cylinder><radius>0.05</radius><length>0.4</length></cylinder></geometry>
      </collision>
    </link>

    <!-- ============================================ -->
    <!-- Pan joint (yaw) — rotates around Z          -->
    <!-- ============================================ -->
    <joint name="pan_joint" type="revolute">
      <parent>base_link</parent>
      <child>pan_link</child>
      <pose>0 0 0.2 0 0 0</pose>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-3.14</lower>
          <upper>3.14</upper>
          <effort>10</effort>
          <velocity>5</velocity>
        </limit>
        <dynamics>
          <damping>0.3</damping>
          <friction>0.1</friction>
        </dynamics>
      </axis>
    </joint>

    <link name="pan_link">
      <inertial>
        <mass>0.05</mass>
        <inertia>
          <ixx>0.0001</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.0001</iyy><iyz>0</iyz>
          <izz>0.0001</izz>
        </inertia>
      </inertial>
      <visual name="pan_visual">
        <geometry><box><size>0.08 0.08 0.04</size></box></geometry>
        <material><ambient>0.2 0.2 0.8 1</ambient></material>
      </visual>
    </link>

    <!-- ============================================ -->
    <!-- Tilt joint (pitch) — rotates around Y        -->
    <!-- ============================================ -->
    <joint name="tilt_joint" type="revolute">
      <parent>pan_link</parent>
      <child>tilt_link</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1.05</lower>   <!-- ~ -60° -->
          <upper>1.05</upper>    <!-- ~ +60° -->
          <effort>5</effort>
          <velocity>3</velocity>
        </limit>
        <dynamics>
          <damping>0.3</damping>
          <friction>0.1</friction>
        </dynamics>
      </axis>
    </joint>

    <link name="tilt_link">
      <inertial>
        <mass>0.03</mass>
        <inertia>
          <ixx>0.00005</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.00005</iyy><iyz>0</iyz>
          <izz>0.00005</izz>
        </inertia>
      </inertial>
      <visual name="tilt_visual">
        <pose>0 0 -0.02 0 0 0</pose>
        <geometry><box><size>0.06 0.06 0.03</size></box></geometry>
        <material><ambient>0.8 0.2 0.2 1</ambient></material>
      </visual>

      <!-- ── Camera sensor ────────────────────── -->
      <sensor name="camera" type="camera">
        <pose>0.04 0 0 0 0 0</pose>
        <always_on>1</always_on>
        <update_rate>30</update_rate>
        <visualize>1</visualize>
        <camera>
          <horizontal_fov>1.047</horizontal_fov>  <!-- ~60° -->
          <image>
            <width>848</width>
            <height>480</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.1</near>
            <far>100</far>
          </clip>
        </camera>
      </sensor>
    </link>

    <!-- ============================================ -->
    <!-- Pan + Tilt PID position controllers          -->
    <!-- Runtime angle update via:                    -->
    <!--   ign topic -t /gazebo/<world>/pan_tilt_     -->
    <!--     camera/<joint>/joint_cmd                 -->
    <!--   -m ignition.msgs.JointCmd                  -->
    <!-- ============================================ -->
    <plugin name="joint_controllers"
            filename="/usr/lib/x86_64-linux-gnu/gazebo-11/plugins/libJointControlPlugin.so">
      <controller type="position">
        <joint>pan_joint</joint>
        <target>0.0</target>
        <pid_gains>30 0 3</pid_gains>
      </controller>
      <controller type="position">
        <joint>tilt_joint</joint>
        <target>0.0</target>
        <pid_gains>30 0 3</pid_gains>
      </controller>
    </plugin>

  </model>
</sdf>
